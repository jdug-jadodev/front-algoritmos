---
interface Props {
  level: number;
}

const { level } = Astro.props;

const levelNames = {
  0: 'Cero Absoluto',
  1: 'Principiante',
  2: 'Intermedio',
  3: 'Avanzado',
  4: 'Experto'
};

const levelColors = {
  0: '#10b981', // green
  1: '#06b6d4', // cyan
  2: '#f59e0b', // amber
  3: '#ec4899', // pink
  4: '#7c3aed'  // violet
};

const levelName = levelNames[level as keyof typeof levelNames] || 'Desconocido';
const levelColor = levelColors[level as keyof typeof levelColors] || '#64748b';
---

<span class="level-badge" style={`--level-color: ${levelColor}`}>
  <span class="level-number">{level}</span>
  <span class="level-name">{levelName}</span>
</span>

<style>
  .level-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.75rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--level-color);
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 700;
    transition: all 0.2s ease;
  }

  .level-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    background: var(--level-color);
    color: var(--bg);
    border-radius: 50%;
    font-family: 'Space Mono', monospace;
    font-size: 0.75rem;
  }

  .level-name {
    color: var(--level-color);
  }

  .level-badge:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: scale(1.05);
  }
</style>
