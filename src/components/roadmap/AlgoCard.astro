---
interface Props {
  id: string;
  name: string;
  level: number;
  complexity: string;
  description: string;
  hasVisualizer: boolean;
}

const { id, name, level, complexity, description, hasVisualizer } = Astro.props;

import LevelBadge from '../layout/LevelBadge.astro';
---

<article class="algo-card" data-algo-id={id} data-level={level}>
  <div class="card-header">
    <h3 class="algo-name">{name}</h3>
    <LevelBadge level={level} />
  </div>
  
  <div class="card-body">
    <div class="complexity">
      <span class="complexity-label">Complejidad:</span>
      <code class="complexity-value">{complexity}</code>
    </div>
    
    <p class="description">{description}</p>
    
    {!hasVisualizer && (
      <div class="status-badge coming-soon">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 2V8L12 10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="2"/>
        </svg>
        Próximamente
      </div>
    )}
  </div>
  
  <div class="card-footer">
    <a href={`/algoritmos/${id}`} class="view-btn">
      Ver algoritmo
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
    
    <button class="complete-btn" type="button" aria-label="Marcar como completado">
      <svg class="check-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M4 10L8 14L16 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</article>

<style>
  .algo-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    position: relative;
    overflow: hidden;
  }

  .algo-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .algo-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow: 0 10px 30px rgba(124, 58, 237, 0.2);
  }

  .algo-card:hover::before {
    opacity: 1;
  }

  .algo-card.completed {
    border-color: var(--match);
  }

  .algo-card.completed::before {
    background: var(--match);
    opacity: 1;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .algo-name {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text);
    margin: 0;
    flex: 1;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .complexity {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
  }

  .complexity-label {
    color: var(--muted);
  }

  .complexity-value {
    font-family: 'Space Mono', monospace;
    color: var(--accent2);
    background: rgba(6, 182, 212, 0.1);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.875rem;
  }

  .description {
    color: var(--muted);
    font-size: 0.9375rem;
    line-height: 1.6;
    margin: 0;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    font-size: 0.8125rem;
    font-weight: 600;
    align-self: flex-start;
  }

  .coming-soon {
    background: rgba(100, 116, 139, 0.1);
    color: var(--muted);
    border: 1px solid rgba(100, 116, 139, 0.3);
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }

  .view-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    background: var(--accent);
    color: white;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.9375rem;
    transition: all 0.2s ease;
    flex: 1;
    justify-content: center;
  }

  .view-btn:hover {
    background: var(--accent2);
    transform: translateX(2px);
  }

  .complete-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: var(--surface);
    border: 2px solid var(--border);
    border-radius: 8px;
    color: var(--muted);
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .complete-btn:hover {
    border-color: var(--match);
    color: var(--match);
    background: rgba(236, 72, 153, 0.1);
  }

  .algo-card.completed .complete-btn {
    background: var(--match);
    border-color: var(--match);
    color: white;
  }

  .check-icon {
    transition: transform 0.2s ease;
  }

  .complete-btn:hover .check-icon {
    transform: scale(1.1);
  }

  @media (max-width: 640px) {
    .algo-card {
      padding: 1.25rem;
    }

    .algo-name {
      font-size: 1.125rem;
    }

    .card-footer {
      flex-direction: column;
      gap: 0.75rem;
    }

    .view-btn {
      width: 100%;
    }

    .complete-btn {
      width: 100%;
    }
  }
</style>
