---
/**
 * Controls - Botones de control para el visualizador
 * 
 * Renderiza los 3 botones principales de control:
 * - Reiniciar: Vuelve al estado inicial (siempre habilitado)
 * - Siguiente paso: Ejecuta un paso del algoritmo
 * - Auto: Inicia/pausa reproducción automática
 * 
 * Los botones deben conectarse a funciones del visualizador mediante
 * IDs únicos que el script del visualizador puede capturar.
 * 
 * @component
 */

interface Props {
  stepDisabled?: boolean;    // Si true, deshabilita "Siguiente paso"
  autoDisabled?: boolean;    // Si true, deshabilita "Auto"
  isAutoPlaying?: boolean;   // Si true, muestra icono de pausa en vez de play
}

const { 
  stepDisabled = false, 
  autoDisabled = false,
  isAutoPlaying = false 
} = Astro.props;
---

<div class="controls-container">
  <button 
    id="resetBtn"
    class="control-btn reset-btn" 
    aria-label="Reiniciar visualización"
    title="Reiniciar (siempre disponible)"
  >
    <span class="btn-icon">🔄</span>
    <span class="btn-text">Reiniciar</span>
  </button>

  <button 
    id="stepBtn"
    class="control-btn step-btn" 
    disabled={stepDisabled}
    aria-label="Ejecutar siguiente paso"
    title="Siguiente paso"
  >
    <span class="btn-icon">→</span>
    <span class="btn-text">Siguiente paso</span>
  </button>

  <button 
    id="autoBtn"
    class="control-btn auto-btn" 
    disabled={autoDisabled}
    aria-label={isAutoPlaying ? 'Pausar reproducción automática' : 'Iniciar reproducción automática'}
    title={isAutoPlaying ? 'Pausar' : 'Auto-play'}
  >
    <span class="btn-icon" id="autoIcon">{isAutoPlaying ? '⏸' : '▶'}</span>
    <span class="btn-text" id="autoText">{isAutoPlaying ? 'Pausar' : 'Auto'}</span>
  </button>
</div>

<style>
  /* ============================================
     CONTENEDOR DE CONTROLES
     ============================================ */
  .controls-container {
    display: flex;
    gap: 12px;
    justify-content: center;
    align-items: center;
    padding: 16px 0;
    flex-wrap: wrap;
  }

  /* ============================================
     BOTONES BASE
     ============================================ */
  .control-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: var(--card);
    border: 2px solid var(--border);
    border-radius: 8px;
    font-family: 'Syne', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
    cursor: pointer;
    transition: all 0.2s ease;
    
    /* Sombra sutil */
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .control-btn:hover:not(:disabled) {
    border-color: var(--accent);
    background: var(--surface);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(124, 58, 237, 0.3);
  }

  .control-btn:active:not(:disabled) {
    transform: translateY(0);
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);
  }

  .control-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    border-color: var(--border);
  }

  .btn-icon {
    font-size: 1.2rem;
    line-height: 1;
  }

  .btn-text {
    line-height: 1;
  }

  /* ============================================
     VARIANTES DE BOTONES
     ============================================ */

  /* Botón Reiniciar - Siempre disponible */
  .reset-btn {
    border-color: var(--muted);
  }

  .reset-btn:hover:not(:disabled) {
    border-color: var(--error);
    box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
  }

  /* Botón Paso - Acción principal */
  .step-btn {
    border-color: var(--accent);
    background: linear-gradient(135deg, var(--card) 0%, var(--surface) 100%);
  }

  .step-btn:hover:not(:disabled) {
    background: var(--accent);
    color: white;
    box-shadow: 0 4px 16px rgba(124, 58, 237, 0.4);
  }

  /* Botón Auto - Toggleable */
  .auto-btn {
    border-color: var(--accent2);
  }

  .auto-btn:hover:not(:disabled) {
    border-color: var(--accent2);
    background: var(--accent2);
    color: var(--bg);
    box-shadow: 0 4px 12px rgba(6, 182, 212, 0.4);
  }

  /* Estado activo del botón Auto (cuando está reproduciendo) */
  .auto-btn[data-playing="true"] {
    background: var(--accent2);
    color: var(--bg);
    border-color: var(--accent2);
  }

  /* ============================================
     ACCESIBILIDAD - Keyboard focus
     ============================================ */
  .control-btn:focus-visible {
    outline: 3px solid var(--accent);
    outline-offset: 2px;
  }

  /* ============================================
     ACCESIBILIDAD - Reduce motion
     ============================================ */
  @media (prefers-reduced-motion: reduce) {
    .control-btn {
      transition: none;
    }
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 768px) {
    .controls-container {
      gap: 8px;
    }

    .control-btn {
      padding: 10px 18px;
      font-size: 0.85rem;
    }

    .btn-icon {
      font-size: 1.1rem;
    }
  }

  @media (max-width: 480px) {
    .controls-container {
      gap: 6px;
      padding: 12px 0;
    }

    .control-btn {
      padding: 8px 14px;
      font-size: 0.8rem;
      gap: 6px;
    }

    .btn-text {
      display: none; /* Mostrar solo iconos en móvil */
    }

    .btn-icon {
      font-size: 1.3rem;
    }
  }
</style>
