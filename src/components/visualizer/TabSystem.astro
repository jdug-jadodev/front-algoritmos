---
/**
 * TabSystem - Sistema de navegación por tabs para visualizadores
 * 
 * Renderiza un sistema de 3-4 tabs con:
 * - Navegación con teclado
 * - Persistencia opcional del tab activo
 * - Animaciones suaves de transición
 * - Estados visuales claros
 * 
 * Uso:
 * <TabSystem tabs={[
 *   { id: 'what', icon: '🧠', label: '¿Qué es?' },
 *   { id: 'how', icon: '📋', label: '¿Cómo funciona?' },
 *   { id: 'demo', icon: '▶️', label: 'Pruébalo' }
 * ]}>
 *   <div slot="what">Contenido...</div>
 *   <div slot="how">Contenido...</div>
 *   <div slot="demo">Contenido...</div>
 * </TabSystem>
 * 
 * @component
 */

interface Tab {
  id: string;
  icon: string;
  label: string;
}

interface Props {
  tabs: Tab[];
  defaultTab?: string;  // ID del tab activo por defecto
}

const { tabs, defaultTab } = Astro.props;
const initialTab = defaultTab || tabs[0]?.id || 'demo';
---

<div class="tab-system">
  <!-- Tab Headers -->
  <div class="tab-headers" role="tablist">
    {tabs.map((tab, _index) => (
      <button
        class={`tab-header ${tab.id === initialTab ? 'active' : ''}`}
        role="tab"
        aria-selected={tab.id === initialTab ? 'true' : 'false'}
        aria-controls={`panel-${tab.id}`}
        id={`tab-${tab.id}`}
        data-tab={tab.id}
        tabindex={tab.id === initialTab ? 0 : -1}
      >
        <span class="tab-icon">{tab.icon}</span>
        <span class="tab-label">{tab.label}</span>
      </button>
    ))}
  </div>

  <!-- Tab Panels -->
  <div class="tab-panels">
    {tabs.map((tab) => (
      <div
        class={`tab-panel ${tab.id === initialTab ? 'active' : ''}`}
        role="tabpanel"
        id={`panel-${tab.id}`}
        aria-labelledby={`tab-${tab.id}`}
        data-panel={tab.id}
        tabindex="0"
      >
        <!-- El contenido de cada tab se renderiza en el visualizador directamente -->
      </div>
    ))}
  </div>
  
  <!-- Contenedores de slots (ocultos, se copiarán a los panels con JS) -->
  <div style="display: none;">
    <div data-slot-content="what"><slot name="what" /></div>
    <div data-slot-content="how"><slot name="how" /></div>
    <div data-slot-content="demo"><slot name="demo" /></div>
    <div data-slot-content="code"><slot name="code" /></div>
  </div>
</div>

<style>
  /* ============================================
     CONTENEDOR PRINCIPAL
     ============================================ */
  .tab-system {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ============================================
     HEADERS DE TABS
     ============================================ */
  .tab-headers {
    display: flex;
    gap: 4px;
    background: var(--surface);
    padding: 8px;
    border-radius: 12px 12px 0 0;
    border-bottom: 2px solid var(--border);
    overflow-x: auto;
    scrollbar-width: thin;
  }

  /* Webkit scrollbar para headers */
  .tab-headers::-webkit-scrollbar {
    height: 4px;
  }

  .tab-headers::-webkit-scrollbar-track {
    background: var(--surface);
  }

  .tab-headers::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 2px;
  }

  /* ============================================
     BOTONES DE TAB
     ============================================ */
  .tab-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    background: transparent;
    border: 2px solid transparent;
    border-radius: 8px;
    font-family: 'Syne', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
    position: relative;
  }

  .tab-header:hover {
    background: var(--card);
    color: var(--text);
    border-color: var(--border);
  }

  .tab-header:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Tab activo */
  .tab-header.active {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
    box-shadow: 0 2px 8px rgba(124, 58, 237, 0.3);
  }

  .tab-header.active:hover {
    background: var(--accent);
    border-color: var(--accent);
  }

  /* Icono y label del tab */
  .tab-icon {
    font-size: 1.1rem;
    line-height: 1;
  }

  .tab-label {
    line-height: 1;
  }

  /* ============================================
     PANELES DE TABS
     ============================================ */
  .tab-panels {
    position: relative;
    min-height: 400px;
    background: var(--bg);
    border-radius: 0 0 12px 12px;
  }

  .tab-panel {
    display: none;
    padding: 24px;
    animation: fadeIn 0.3s ease;
  }

  .tab-panel.active {
    display: block;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ============================================
     ACCESIBILIDAD - Reduce motion
     ============================================ */
  @media (prefers-reduced-motion: reduce) {
    .tab-header,
    .tab-panel {
      transition: none;
      animation: none;
    }

    .tab-panel.active {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 768px) {
    .tab-header {
      padding: 10px 16px;
      font-size: 0.85rem;
      gap: 6px;
    }

    .tab-icon {
      font-size: 1rem;
    }

    .tab-panel {
      padding: 20px;
    }

    .tab-panels {
      min-height: 350px;
    }
  }

  @media (max-width: 480px) {
    .tab-headers {
      padding: 6px;
      gap: 3px;
    }

    .tab-header {
      padding: 8px 12px;
      font-size: 0.8rem;
    }

    /* En móvil, ocultar labels y mostrar solo iconos */
    .tab-label {
      display: none;
    }

    .tab-icon {
      font-size: 1.2rem;
    }

    .tab-panel {
      padding: 16px;
    }

    .tab-panels {
      min-height: 300px;
    }
  }
</style>

<script>
  /**
   * Script cliente para manejo de tabs
   * - Navegación con click
   * - Navegación con teclado (flechas)
   * - Persistencia opcional en sessionStorage
   */

  class TabSystem {
    private headers: NodeListOf<HTMLElement>;
    private panels: NodeListOf<HTMLElement>;
    private currentTab: string;

    constructor() {
      this.headers = document.querySelectorAll('.tab-header');
      this.panels = document.querySelectorAll('.tab-panel');
      
      // Obtener tab activo inicial
      const activeHeader = document.querySelector('.tab-header.active') as HTMLElement;
      this.currentTab = activeHeader?.dataset.tab || '';

      this.init();
    }

    init() {
      // Copiar contenido de slots a panels
      this.panels.forEach(panel => {
        const panelId = panel.dataset.panel;
        const slotContent = document.querySelector(`[data-slot-content="${panelId}"]`);
        if (slotContent) {
          while (slotContent.firstChild) {
            panel.appendChild(slotContent.firstChild);
          }
        }
      });

      // Event listeners para clicks
      this.headers.forEach(header => {
        header.addEventListener('click', () => {
          const tabId = header.dataset.tab;
          if (tabId) this.switchTab(tabId);
        });

        // Navegación con teclado
        header.addEventListener('keydown', (e) => {
          this.handleKeyboard(e as KeyboardEvent);
        });
      });

      // Recuperar tab guardado si existe
      const savedTab = sessionStorage.getItem('activeTab');
      if (savedTab) {
        this.switchTab(savedTab);
      }
    }

    switchTab(tabId: string) {
      // Desactivar tab actual
      this.headers.forEach(h => {
        h.classList.remove('active');
        h.setAttribute('aria-selected', 'false');
        h.tabIndex = -1;
      });

      this.panels.forEach(p => {
        p.classList.remove('active');
      });

      // Activar nuevo tab
      const newHeader = document.querySelector(`[data-tab="${tabId}"]`) as HTMLElement;
      const newPanel = document.querySelector(`[data-panel="${tabId}"]`) as HTMLElement;

      if (newHeader && newPanel) {
        newHeader.classList.add('active');
        newHeader.setAttribute('aria-selected', 'true');
        newHeader.tabIndex = 0;
        newPanel.classList.add('active');

        this.currentTab = tabId;

        // Guardar en sessionStorage
        sessionStorage.setItem('activeTab', tabId);

        // Focus en el nuevo header
        newHeader.focus();
      }
    }

    handleKeyboard(e: KeyboardEvent) {
      const headersArray = Array.from(this.headers);
      const currentIndex = headersArray.findIndex(h => h.dataset.tab === this.currentTab);

      let nextIndex = currentIndex;

      // Navegar con flechas
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
        e.preventDefault();
        nextIndex = (currentIndex + 1) % headersArray.length;
      } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
        e.preventDefault();
        nextIndex = (currentIndex - 1 + headersArray.length) % headersArray.length;
      } else if (e.key === 'Home') {
        e.preventDefault();
        nextIndex = 0;
      } else if (e.key === 'End') {
        e.preventDefault();
        nextIndex = headersArray.length - 1;
      } else {
        return;
      }

      const nextHeader = headersArray[nextIndex];
      const nextTab = nextHeader?.dataset.tab;
      if (nextTab) this.switchTab(nextTab);
    }
  }

  // Inicializar cuando el DOM esté listo
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      new TabSystem();
    });
  } else {
    new TabSystem();
  }
</script>
